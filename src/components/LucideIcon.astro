---
/**
 * Minimal Lucide-style icon renderer.
 * Kept in plain JS to avoid build issues in Astro frontmatter.
 *
 * Props:
 * - name: string (e.g. "arrow-right")
 * - size: number (default 18)
 * - class: string (default "text-stone-400")
 * - strokeWidth: number (default 1.5)
 */
const name = Astro.props.name;
const size = Astro.props.size ?? 18;
const className = Astro.props.class ?? 'text-stone-400';
const strokeWidth = Astro.props.strokeWidth ?? 1.5;

const common = {
  xmlns: 'http://www.w3.org/2000/svg',
  width: size,
  height: size,
  viewBox: '0 0 24 24',
  fill: 'none',
  stroke: 'currentColor',
  'stroke-width': strokeWidth,
  'stroke-linecap': 'round',
  'stroke-linejoin': 'round',
  class: className,
  'aria-hidden': 'true',
  focusable: 'false',
};
---

{name === 'arrow-right' && (
  <svg {...common}>
    <path d="M5 12h14" />
    <path d="m12 5 7 7-7 7" />
  </svg>
)}

{name === 'check' && (
  <svg {...common}>
    <path d="M20 6 9 17l-5-5" />
  </svg>
)}

{name === 'check-circle-2' && (
  <svg {...common}>
    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
    <path d="M22 4 12 14.01l-3-3" />
  </svg>
)}

{name === 'dot' && (
  <svg {...common}>
    <circle cx="12" cy="12" r="1.75" fill="currentColor" stroke="none" />
  </svg>
)}

{name === 'folder' && (
  <svg {...common}>
    <path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7l-2-2H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2z" />
