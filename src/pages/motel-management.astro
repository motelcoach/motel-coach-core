---
import BaseLayout from '../layouts/BaseLayout.astro';
import LucideIcon from '../components/LucideIcon.astro';
---

<BaseLayout title="How to Run a Motel | Motel Management Systems | Motel Coach" description="A systems-first guide to motel management systems, staffing, distribution, and operations for independent Australian motels.">
  <!-- Hero -->
  <section class="bg-[#F9F9F8] border-b border-stone-200 pt-24 pb-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-4xl" data-reveal="up">
        <h1 class="text-5xl md:text-7xl font-semibold text-stone-900 tracking-tight text-balance">
          How to Run a Motel: The Systems-First Guide to High-Performance Management.
        </h1>
        <p class="mt-6 text-lg md:text-xl text-stone-500 leading-relaxed text-balance">
          Stop &quot;buying a job&quot; and start building a high-profit asset. Whether you are taking over your first 10-room property or scaling a regional group, these are the operational blueprints used by the industry&apos;s top 1%.
        </p>
      </div>

      <div class="mt-10" data-reveal="up">
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/motel-management-training-course" class="inline-flex items-center justify-center rounded-lg bg-[#4A554E] px-6 py-3.5 text-sm font-medium text-white shadow-sm hover:bg-[#3d4640] hover:shadow-lg transition">
            Join the Motel Mastery Course
          </a>
          <a href="/contact" class="inline-flex items-center justify-center rounded-lg border border-stone-200 bg-white px-6 py-3.5 text-sm font-medium text-stone-900 shadow-sm hover:bg-stone-50 hover:shadow-lg transition">
            Book Your Free Strategy Session
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Choose Your Support -->
  <section class="bg-white py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl" data-reveal="up">
        <h2 class="text-2xl md:text-3xl font-semibold text-stone-900 tracking-tight text-balance">
          Choose your support.
        </h2>
        <p class="mt-4 text-stone-500 leading-relaxed">
          Three options. Same outcome: a motel that runs on systems—not your stress response.
        </p>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-3">
        <a href="/motel-management-book" class="group rounded-2xl border border-stone-200 bg-stone-50 p-6 shadow-sm hover:shadow-lg transition" data-reveal="up">
          <p class="text-xs font-semibold uppercase tracking-widest text-stone-400">The book</p>
          <h3 class="mt-3 text-lg font-semibold text-stone-900 tracking-tight">
            The Essential Guide to Motel Management.
          </h3>
          <p class="mt-2 text-sm text-stone-500 leading-relaxed">
            Perfect for those starting their research.
          </p>
          <p class="mt-4 text-sm font-medium text-[#4A554E] group-hover:underline inline-flex items-center gap-2">
            View the book
            <LucideIcon name="arrow-right" size={18} class="text-[#4A554E]" />
          </p>
        </a>

        <a href="/motel-management-training-course" class="group rounded-2xl border border-stone-200 bg-stone-50 p-6 shadow-sm hover:shadow-lg transition" data-reveal="up">
          <p class="text-xs font-semibold uppercase tracking-widest text-stone-400">The course</p>
          <h3 class="mt-3 text-lg font-semibold text-stone-900 tracking-tight">
            The Motel Mastery Course.
          </h3>
          <p class="mt-2 text-sm text-stone-500 leading-relaxed">
            A clinical 7–21 day deep dive for managers and owners.
          </p>
          <p class="mt-4 text-sm font-medium text-[#4A554E] group-hover:underline inline-flex items-center gap-2">
            View the course
            <LucideIcon name="arrow-right" size={18} class="text-[#4A554E]" />
          </p>
        </a>

        <a href="/motel-performance-audit" class="group rounded-2xl border border-stone-200 bg-stone-50 p-6 shadow-sm hover:shadow-lg transition" data-reveal="up">
          <p class="text-xs font-semibold uppercase tracking-widest text-stone-400">Consultancy</p>
          <h3 class="mt-3 text-lg font-semibold text-stone-900 tracking-tight">
            Operational Performance Audit.
          </h3>
          <p class="mt-2 text-sm text-stone-500 leading-relaxed">
            For established owners wanting a professional to find the hidden profit.
          </p>
          <p class="mt-4 text-sm font-medium text-[#4A554E] group-hover:underline inline-flex items-center gap-2">
            See audit details
            <LucideIcon name="arrow-right" size={18} class="text-[#4A554E]" />
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- Pillar Content (Reading-focused with sticky TOC) -->
  <section class="bg-white pb-32">
    <div class="max-w-6xl mx-auto px-6 grid gap-12 md:grid-cols-12">
      <aside class="md:col-span-4">
        <div class="md:sticky md:top-28 space-y-4" data-reveal="fade">
          <p class="text-xs font-semibold uppercase tracking-widest text-stone-400">
            Table of contents
          </p>
          <nav class="space-y-2 text-sm">
            <a class="block text-stone-500 hover:text-[#4A554E] transition-colors" href="#why-fail">Why Most Small Motels Fail</a>
            <a class="block text-stone-500 hover:text-[#4A554E] transition-colors" href="#pillars">The 4 Pillars of a Motel System</a>
            <a class="block text-stone-500 hover:text-[#4A554E] transition-colors" href="#small-motel">How to Run a Small Motel Business</a>
            <a class="block text-stone-500 hover:text-[#4A554E] transition-colors" href="#operator-proof">Operator Proof</a>
            <a class="block text-stone-500 hover:text-[#4A554E] transition-colors" href="#faq">FAQ</a>
          </nav>
          <a href="/contact" class="inline-flex items-center gap-2 text-sm font-medium text-[#4A554E] hover:text-[#3d4640] transition-colors">
            Speak with an advisor
            <LucideIcon name="arrow-right" size={18} class="text-[#4A554E]" />
          </a>
        </div>
      </aside>

      <article class="md:col-span-8">
        <div class="prose prose-stone prose-lg max-w-none" data-reveal="up">
          <h2 id="why-fail">Why Most Small Motels Fail</h2>
          <p>
            Most small motels don’t fail because the owner is lazy. They fail because the operation is built on <strong>reactive management</strong> instead of <strong>systemic management</strong>.
          </p>
          <p>
            Reactive management is firefighting: chasing complaints, patching rosters, discounting to fill gaps, and living inside the front desk. Systemic management is repeatable: clear standards, documented SOPs, and a weekly rhythm that keeps the business stable even when staff change.
          </p>

          <h2 id="pillars">The 4 Pillars of a Motel System</h2>
          <p>
            A motel system is not a binder. It is the minimum set of operational rules that makes performance predictable.
          </p>
        </div>

        <div class="mt-8 grid gap-5 sm:grid-cols-2" data-reveal="up">
          {[
            {
              title: 'Operations & Housekeeping',
              desc: 'The “engine room”. Standards, checklists, and quality control that protect reviews and reduce rework.',
              icon: (
                <svg class="h-5 w-5 text-stone-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 19h16" />
                  <path d="M7 19V8a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v11" />
                  <path d="M9 11h6" />
                </svg>
              ),
            },
            {
              title: 'Revenue & Distribution',
              desc: 'OTA vs direct strategy, rate rules, parity control, and channel mix discipline.',
              icon: (
                <svg class="h-5 w-5 text-stone-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 19V5" />
                  <path d="M4 19h16" />
                  <path d="M7 14l3-3 3 2 4-6" />
                </svg>
              ),
            },
            {
              title: 'Guest Experience',
              desc: 'The “trust infrastructure”. Messaging, expectations, review velocity, and service consistency.',
              icon: (
                <svg class="h-5 w-5 text-stone-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 21s7-4.5 7-11a7 7 0 1 0-14 0c0 6.5 7 11 7 11z" />
                  <path d="M12 10.5a2 2 0 1 0 0-4 2 2 0 0 0 0 4z" />
                </svg>
              ),
            },
            {
              title: 'Staffing & Autonomy',
              desc: 'How to step away from the front desk without quality collapsing. Roles, training, and ownership.',
              icon: (
                <svg class="h-5 w-5 text-stone-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                  <path d="M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z" />
                  <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                  <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                </svg>
              ),
            },
          ].map((p) => (
            <div class="rounded-2xl border border-stone-200 bg-[#F9F9F8] p-6 shadow-sm hover:shadow-lg transition">
              <div class="flex items-start gap-3">
                <div class="mt-0.5 flex h-10 w-10 items-center justify-center rounded-xl bg-white border border-stone-200">
                  {p.icon}
                </div>
                <div>
                  <h3 class="text-base font-semibold text-stone-900 tracking-tight">{p.title}</h3>
                  <p class="mt-1 text-sm text-stone-500 leading-relaxed">{p.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-12 prose prose-stone prose-lg max-w-none" data-reveal="up">
          <h2 id="small-motel">How to Run a Small Motel Business (10–25 rooms)</h2>
          <p>
            If you are stretched thin, the answer is not “work harder.” The answer is <strong>reduce variation</strong>. Build a weekly rhythm that forces consistency:
          </p>
          <ul>
            <li><strong>Daily:</strong> arrivals/departures, cash control, defect triage.</li>
            <li><strong>Weekly:</strong> rate review, channel mix review, roster performance.</li>
            <li><strong>Monthly:</strong> deep clean cycle, maintenance debt review, training refresh.</li>
          </ul>
          <p>
            A small motel becomes profitable when the owner stops being the system and starts installing the system.
          </p>

          <h2 id="operator-proof">Operator Proof</h2>
        </div>

        <div id="operator-proof" class="mt-6 rounded-2xl border border-stone-200 bg-stone-50 p-8 shadow-sm" data-reveal="up">
          <p class="text-sm font-semibold text-stone-900">
            We aren&apos;t just theorists.
          </p>
          <p class="mt-2 text-stone-500 leading-relaxed">
            We&apos;ve run 6-room boutique stays and 16-property groups. We know how to clean a room, manage a GDS, and handle a midnight check-in.
          </p>
        </div>

        <div class="mt-14" data-reveal="up">
          <h2 id="faq" class="text-2xl md:text-3xl font-semibold text-stone-900 tracking-tight text-balance">
            Motel management FAQ
          </h2>
          <p class="mt-4 text-stone-500 leading-relaxed">
            Practical answers to the questions owners actually ask.
          </p>

          <div class="mt-8 space-y-4">
            {[
              {
                q: 'How much does it cost to run a motel?',
                a: 'It depends on room count, staffing model, and utilities, but the biggest controllables are wages, commissions, and maintenance debt. A system reduces variation so costs stop creeping upward silently.',
              },
              {
                q: 'What is the best motel management software?',
                a: 'The best PMS is the one your team uses correctly. Focus on clean data, consistent workflows, and reporting discipline before switching platforms.',
              },
              {
                q: 'How do I run a motel without being on the front desk every day?',
                a: 'Document standards, train to checklists, and build a weekly management rhythm. Autonomy is earned by systems—never by hope.',
              },
              {
                q: 'How do I find a reliable motel manager?',
                a: 'Hire for discipline and consistency, then support them with a playbook. A strong manager will still fail in a weak system.',
              },
              {
                q: 'How do I reduce Booking.com dependency?',
                a: 'Fix parity, strengthen direct conversion, and run OTAs as billboards. The goal is channel mix control, not channel elimination.',
              },
              {
                q: 'What are the core motel management systems I need first?',
                a: 'Housekeeping standards, cash and rate integrity, distribution checks, maintenance triage, and review velocity. Start with the engine room.',
              },
              {
                q: 'How do I train front desk staff quickly?',
                a: 'Use scripts, checklists, and real scenarios. Reduce variation in guest handling and daily admin so errors stop recurring.',
              },
              {
                q: 'How often should I change room rates?',
                a: 'Weekly is a minimum. In high-demand markets you can review more frequently, but rules matter more than frequency.',
              },
              {
                q: 'How do I improve motel reviews?',
                a: 'Set standards, reduce room defects, and implement a simple review request workflow. Reviews are a system output.',
              },
              {
                q: 'How do I run a small motel business profitably?',
                a: 'Protect margin first: wage discipline, parity control, defect reduction, and direct conversion. Small motels win by consistency, not complexity.',
              },
            ].map((item) => (
              <details class="group rounded-xl border border-stone-200 bg-white p-4 shadow-sm hover:shadow-lg transition">
                <summary class="flex cursor-pointer items-center justify-between gap-4 text-left">
                  <span class="text-sm md:text-base font-semibold text-stone-900">
                    {item.q}
                  </span>
                  <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full border border-stone-200 text-stone-500 transition group-open:rotate-45">
                    +
                  </span>
                </summary>
                <p class="mt-3 text-sm text-stone-500 leading-relaxed">
                  {item.a}
                </p>
              </details>
            ))}
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- Sticky Footer CTA (appears after hero) -->
  <div id="sticky-footer-cta" class="fixed inset-x-0 bottom-0 z-40 hidden">
    <div class="bg-white/90 backdrop-blur border-t border-stone-200">
      <div class="max-w-6xl mx-auto px-6 py-3 flex flex-col sm:flex-row items-center justify-between gap-3">
        <p class="text-sm text-stone-700">
          <span class="font-semibold text-stone-900">Ready to systemize your motel?</span> Start with the fastest path.
        </p>
        <div class="flex w-full sm:w-auto gap-3">
          <a href="/motel-management-training-course" class="flex-1 sm:flex-none inline-flex items-center justify-center rounded-lg bg-[#4A554E] px-5 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-[#3d4640] transition">
            Start the Course
          </a>
          <a href="/motel-performance-audit" class="flex-1 sm:flex-none inline-flex items-center justify-center rounded-lg border border-stone-200 bg-white px-5 py-2.5 text-sm font-medium text-stone-900 shadow-sm hover:bg-stone-50 transition">
            Book an Audit
          </a>
        </div>
      </div>
    </div>
  </div>

  <div id="sticky-footer-sentinel" aria-hidden="true"></div>

  <script>
    (function () {
      const bar = document.getElementById('sticky-footer-cta');
      const sentinel = document.getElementById('sticky-footer-sentinel');
      if (!bar || !sentinel) return;

      const io = new IntersectionObserver(
        (entries) => {
          const entry = entries[0];
          // When sentinel is visible (top of page), hide bar. Once scrolled past, show bar.
          if (entry.isIntersecting) bar.classList.add('hidden');
          else bar.classList.remove('hidden');
        },
        { root: null, threshold: 0 }
      );

      // Place sentinel right after hero in flow: it will scroll away quickly.
      io.observe(sentinel);
    })();
  </script>
</BaseLayout>
