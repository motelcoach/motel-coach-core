---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Revenue Management Course Waitlist | Motel Coach" hideFooterCta>
  <!-- Hero (Minimalist) -->
  <section class="bg-[#F9F9F8] border-b border-stone-200 pt-24 pb-16">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h1 class="text-5xl md:text-7xl font-semibold text-stone-900 tracking-tight text-balance" data-reveal="up">
        The Motel Revenue Management Course
      </h1>
      <p class="mt-6 text-lg md:text-xl text-stone-500 leading-relaxed text-balance max-w-2xl mx-auto" data-reveal="up">
        Practical revenue discipline for Australian motels—so you stop discounting and start controlling yield.
      </p>
      <a
        href="#waitlist"
        class="mt-8 inline-flex items-center justify-center rounded-lg bg-[#4A554E] px-8 py-4 text-base font-medium text-white shadow-sm hover:bg-[#3d4640] hover:shadow-lg transition"
        data-reveal="up"
      >
        Join the waitlist
      </a>
    </div>
  </section>

  <!-- Course Syllabus at a Glance -->
  <section class="bg-white py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl mx-auto text-center" data-reveal="up">
        <h2 class="text-2xl md:text-3xl font-semibold text-stone-900 tracking-tight text-balance">
          Course syllabus at a glance
        </h2>
        <p class="mt-4 text-stone-500 leading-relaxed">
          Three modules that fix the biggest pricing mistakes and channel leakage.
        </p>
      </div>

      <div class="mt-10 max-w-2xl mx-auto rounded-2xl border border-stone-200 bg-[#F9F9F8] p-8" data-reveal="up">
        <ul class="space-y-4">
          {[
            'Pricing rules: set discipline you can run weekly without overthinking',
            'Pickup control: read pace and compression early (no panic discounting)',
            'Channel mix: protect margin with parity and inventory control',
          ].map((t) => (
            <li class="flex items-start gap-3 text-stone-500">
              <svg class="mt-0.5 h-5 w-5 text-stone-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" />
              </svg>
              <span class="leading-relaxed">{t}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Waitlist Form -->
  <section id="waitlist" class="bg-white pb-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-xl mx-auto text-center" data-reveal="up">
        <h2 class="text-2xl md:text-3xl font-semibold text-stone-900 tracking-tight text-balance">
          Get notified when enrollment opens.
        </h2>
        <p class="mt-4 text-stone-500 leading-relaxed">
          Join the waitlist and we&apos;ll email you first.
        </p>
      </div>

      <div id="revenue-waitlist-success" class="hidden mt-8 max-w-xl mx-auto text-center py-6 bg-[#4A554E]/10 rounded-2xl">
        <p class="font-semibold text-stone-900 mb-1">You&apos;re on the list!</p>
        <p class="text-sm text-stone-500">We&apos;ll email you first when enrollment opens.</p>
      </div>
      <form id="revenue-waitlist-form" class="mt-8 max-w-xl mx-auto flex flex-col sm:flex-row gap-3" action="https://hooks.zapier.com/hooks/catch/26131104/upwyerc/" method="POST" data-reveal="up">
        <input type="hidden" name="source_page" value="Revenue Management Course Waitlist" />
        <input type="hidden" name="form_type" value="waitlist" />
        <input type="hidden" name="waitlist" value="revenue-management-course" />
        <input
          type="email"
          name="email"
          required
          placeholder="you@example.com"
          class="flex-1 px-4 py-3 rounded-lg border border-stone-200 bg-white text-sm text-stone-900 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-[#4A554E] focus:border-transparent"
        />
        <button type="submit" class="px-6 py-3 rounded-lg bg-[#4A554E] text-white text-sm font-medium shadow-sm hover:bg-[#3d4640] hover:shadow-lg transition">
          Join waitlist
        </button>
      </form>

      <p class="mt-4 text-center text-xs text-stone-400" data-reveal="fade">
        Join other Australian operators improving their yield and channel mix.
      </p>
    </div>
  </section>
<script>
  document.getElementById('revenue-waitlist-form').addEventListener('submit', async function (e) {
    e.preventDefault();
    const btn = this.querySelector('button[type="submit"]');
    const original = btn.textContent.trim();
    btn.disabled = true;
    btn.textContent = 'Joining…';
    try {
      const res = await fetch(this.action, { method: 'POST', body: new URLSearchParams(new FormData(this)) });
      if (!res.ok) throw new Error();
      this.classList.add('hidden');
      document.getElementById('revenue-waitlist-success').classList.remove('hidden');
    } catch {
      btn.disabled = false;
      btn.textContent = original;
      alert('Something went wrong. Please try again.');
    }
  });
</script>
</BaseLayout>

