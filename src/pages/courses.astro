---
import BaseLayout from '../layouts/BaseLayout.astro';
import LucideIcon from '../components/LucideIcon.astro';

const courses = [
  {
    slug: 'motel-management-training-course',
    title: 'Learn Motel Management',
    description: 'The flagship 21-day transition blueprint. Move from reactive firefighting to systems-based ownership without the profit drain.',
    format: 'Self-Paced Video',
    badge: '01',
    waitlist: false,
  },
  {
    slug: 'learn-guest-point-pms',
    title: 'Learn GuestPoint PMS',
    description: 'Data hygiene, reporting, and operational daily workflows. Master the PMS that powers your property so nothing slips through the cracks.',
    format: 'Self-Paced Video',
    badge: '02',
    waitlist: false,
  },
  {
    slug: 'motel-marketing',
    title: 'Learn Motel Marketing',
    description: 'Direct booking funnels and breaking OTA dependency. Turn your website into a capital asset that compounds your margin.',
    format: 'Self-Paced Video',
    badge: '03',
    waitlist: true,
    waitlistHref: '/motel-marketing-course-waitlist',
  },
  {
    slug: 'motel-revenue-management',
    title: 'Learn Revenue Management',
    description: 'Dynamic pricing, yield optimization, and margin expansion. Stop leaving money on the table with institutional-grade revenue discipline.',
    format: 'Self-Paced Video',
    badge: '04',
    waitlist: true,
    waitlistHref: '/motel-revenue-management-course-waitlist',
  },
];
---

<BaseLayout title="Training Programs | Motel Coach" hideFooterCta>
  <!-- 1. Executive Hero (aligned with pillar pages) -->
  <section class="bg-[#F9F9F8] border-b border-stone-200 py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-12 gap-12 items-start">
        <div class="md:col-span-8" data-reveal="up">
          <p class="text-xs font-semibold uppercase tracking-widest text-[#4A554E] mb-4">
            Training &amp; Certification
          </p>
          <h1 class="text-4xl md:text-5xl font-semibold text-stone-900 tracking-tight text-balance mb-6">
            Operational mastery for independent motels.
          </h1>
          <p class="text-lg md:text-xl text-stone-500 leading-relaxed text-balance">
            Upskill your management team and install self-sustaining motel systems without needing to be on-site 24/7. Choose a specific system to master below.
          </p>
        </div>
        <div class="md:col-span-4" data-reveal="up">
          <div class="bg-white border border-stone-200 p-6 rounded-xl shadow-sm hover:shadow-lg transition sticky top-32">
            <p class="text-xs font-semibold uppercase tracking-widest text-stone-400 mb-3">
              What these courses cover
            </p>
            <ul class="space-y-3 text-sm text-stone-600">
              {[
                'Core motel management systems and checklists',
                'Front desk training and PMS confidence',
                'Motel marketing levers for direct bookings',
                'Revenue management and booking-dot-com rank',
              ].map((item) => (
                <li class="flex items-start gap-2">
                  <span class="mt-0.5">
                    <LucideIcon name="dot" size={18} class="text-stone-400" />
                  </span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. The Course Grid -->
  <section class="w-full bg-[#F9F9F8] py-16 md:py-24 border-y border-stone-200">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-6">
        {courses.map((course) => {
          const href = course.waitlist ? (course.waitlistHref ?? `/contact?waitlist=${course.slug}`) : `/${course.slug}`;
          const ctaText = course.waitlist ? 'Join Waitlist' : 'View Curriculum';
          return (
            <a
              href={href}
              class="group block bg-white border border-stone-200 rounded-xl p-8 shadow-sm hover:shadow-lg hover:border-stone-300 transition-all duration-200"
              data-reveal="up"
            >
              <div class="flex items-start justify-between gap-4 mb-6">
                <div class="w-10 h-10 rounded-lg bg-[#4A554E]/10 flex items-center justify-center flex-shrink-0">
                  <span class="text-[#4A554E] font-semibold text-sm">{course.badge}</span>
                </div>
                {course.waitlist && (
                  <span class="text-xs font-semibold uppercase tracking-widest text-stone-400 bg-stone-100 px-3 py-1.5 rounded-full">
                    Coming soon
                  </span>
                )}
              </div>
              <div class="flex items-start justify-between gap-4 mb-3">
                <h2 class="text-xl md:text-2xl font-semibold text-stone-900 tracking-tight group-hover:text-[#4A554E] transition-colors">
                  {course.title}
                </h2>
                <span class="text-base font-bold text-[#4A554E] whitespace-nowrap bg-[#4A554E]/15 px-3 py-1.5 rounded-lg">From $89</span>
              </div>
              <p class="text-stone-500 leading-relaxed mb-4">
                {course.description}
              </p>
              <span class="inline-block text-xs font-medium uppercase tracking-widest text-stone-400 mb-4">
                {course.format}
              </span>
              <div class="mb-6">
                <span class="inline-flex items-center gap-2 text-sm font-medium text-[#4A554E]">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" aria-hidden="true">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                  </svg>
                  Certificate on completion
                </span>
              </div>
              <span class="inline-flex items-center gap-1.5 text-sm font-medium text-[#4A554E] group-hover:text-[#3d4640] transition-colors">
                {ctaText}
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 3. Bottom CTA -->
  <section class="w-full bg-[#F9F9F8] py-16 md:py-24 border-t border-stone-200">
    <div class="max-w-3xl mx-auto px-6 text-center" data-reveal="up">
      <h2 class="text-2xl md:text-3xl font-semibold text-stone-900 tracking-tight mb-4 text-balance">
        Want the right course for your role?
      </h2>
      <p class="text-stone-500 leading-relaxed mb-7">
        Tell us what you&apos;re running and what you&apos;re stuck on. We&apos;ll point you to the fastest path.
      </p>
      <a
        href="/contact?topic=training&message=Help%20me%20choose%20the%20right%20course."
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#4A554E] text-white text-base font-medium rounded-lg hover:bg-[#3d4640] transition shadow-sm hover:shadow-lg"
      >
        Contact &amp; Course Recommendation
        <LucideIcon name="arrow-right" size={18} class="text-white" />
      </a>
    </div>
  </section>
</BaseLayout>
