---
import BaseLayout from '../layouts/BaseLayout.astro';
import LucideIcon from '../components/LucideIcon.astro';
---

<BaseLayout title="Motel Marketing | Motel Coach" hideFooterCta>
  <!-- 1. Hero (Minimalist & High-Impact) -->
  <section class="bg-[#F9F9F8] border-b border-stone-200 pt-24 pb-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid gap-10 md:grid-cols-12 items-start">
        <div class="md:col-span-7" data-reveal="up">
          <h1 class="text-5xl md:text-7xl font-semibold text-stone-900 tracking-tight text-balance">
            Motel Marketing that drives direct bookings.
          </h1>
          <p class="mt-6 text-lg md:text-xl text-stone-500 leading-relaxed text-balance">
            We install a practical marketing system for independent Australian motels—so “Direct” becomes the default choice, not the lucky outcome.
          </p>
          <a
            href="/contact"
            class="mt-8 inline-flex items-center justify-center rounded-lg bg-[#4A554E] px-8 py-4 text-base font-medium text-white shadow-sm hover:bg-[#3d4640] hover:shadow-lg transition"
          >
            Book Your Free Strategy Session
          </a>
          <p class="mt-4 text-sm text-stone-500">
            Prefer to train your team?{' '}
            <a href="/motel-marketing-course-waitlist" class="font-medium text-[#4A554E] hover:text-[#3d4640] hover:underline inline-flex items-center gap-2">
              Join the Marketing Course waitlist
              <LucideIcon name="arrow-right" size={18} class="text-[#4A554E]" />
            </a>
          </p>
        </div>

        <!-- Minimalist Google Search Mockup (Tailwind only) -->
        <div class="md:col-span-5" data-reveal="up">
          <div class="rounded-2xl border border-stone-200 bg-white p-6 shadow-sm">
            <div class="rounded-full border border-stone-200 bg-stone-50 px-4 py-3">
              <p class="text-sm text-stone-600">
                Motels in <span class="text-stone-400">[Your Location]</span>
              </p>
            </div>

            <div class="mt-5 rounded-2xl border border-stone-200 bg-white p-5">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-sm font-semibold text-stone-900">
                    Motel Coach / <span class="text-stone-400">[Your Motel]</span>
                  </p>
                  <p class="mt-1 text-xs text-stone-500">
                    Official site. Fast booking path. Clear room facts.
                  </p>
                </div>
                <span class="inline-flex items-center gap-1.5 rounded-full bg-[#4A554E]/10 px-3 py-1 text-xs font-semibold text-[#4A554E]">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                  Official site
                </span>
              </div>
            </div>

            <p class="mt-4 text-xs text-stone-400">
              The goal: make “Direct” the obvious option.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Motel Marketing Pillar Content -->
  <section class="bg-white py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl" data-reveal="up">
        <h2 class="text-2xl md:text-3xl font-semibold text-stone-900 tracking-tight text-balance">
          The 9-Step Motel Marketing System
        </h2>
        <p class="mt-4 text-stone-500 leading-relaxed">
          Clean, sequential, and designed for real motel operations. No messy grids. No fluff.
        </p>
      </div>

      <div class="mt-12 space-y-10">
        {[
          {
            number: '01',
            title: 'Direct Booking Foundations',
            body: 'Clarify your direct booking path: website, phone, and email. Rates are clear. Policies are simple. Mobile booking is frictionless.',
          },
          {
            number: '02',
            title: 'OTA Strategy (Not Dependence)',
            body: 'Use OTAs as billboards, not landlords. Tune Booking.com and Expedia to feed direct demand while controlling commission and cancellation risk.',
          },
          {
            number: '03',
            title: 'Website Speed & Conversion',
            body: 'Target sub-2 second loads on patchy regional connections. Clear room facts, fast booking, and clean layout turn visits into bookings.',
          },
          {
            number: '04',
            title: 'Local SEO & Maps',
            body: 'Optimise Google Business Profile, local pages, and content so “motel near me” and town searches put you in the top map results.',
          },
          {
            number: '05',
            title: 'Google Hotel Ads & Interception',
            body: 'Show your direct rate next to the OTAs when guests are ready to book. Intercept intent at the moment of decision.',
          },
          {
            number: '06',
            title: 'Pricing & Offer Structure',
            body: 'Align marketing with simple pricing rules—weekday vs weekend, events, fenced offers—so campaigns and rates support each other.',
          },
          {
            number: '07',
            title: 'Reputation & Review Velocity',
            body: 'Increase review volume with a simple, compliant prompt system. Recent reviews lift click-through, bookings, and your rank.',
          },
        ].map((step) => (
          <div class="grid md:grid-cols-12 gap-6 items-start" data-reveal="up">
            <div class="md:col-span-2">
              <div class="text-5xl md:text-6xl font-semibold text-stone-200 tracking-tight leading-none">
                {step.number}
              </div>
            </div>
            <div class="md:col-span-10">
              <h3 class="text-xl md:text-2xl font-semibold text-stone-900 tracking-tight">
                {step.title}
              </h3>
              <p class="mt-2 text-stone-500 leading-relaxed">
                {step.body}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Premium Insights: AI + Schema -->
  <section class="bg-stone-50 border-y border-stone-200 py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="space-y-12">
        <div class="grid md:grid-cols-12 gap-6 items-start" data-reveal="up">
          <div class="md:col-span-2">
            <div class="text-5xl md:text-6xl font-semibold text-stone-200 tracking-tight leading-none">
              08
            </div>
          </div>
          <div class="md:col-span-10">
            <h3 class="text-xl md:text-2xl font-semibold text-stone-900 tracking-tight">
              AI Marketing: Fact Layer vs. Fluff
            </h3>
            <p class="mt-2 text-stone-500 leading-relaxed">
              AI tools don’t rank adjectives. They rank facts. Replace fluffy copy with dense, verifiable details: King bed sizes, truck parking, Wi‑Fi speeds, late check‑in rules, and real distances.
            </p>
          </div>
        </div>

        <div class="grid md:grid-cols-12 gap-6 items-start" data-reveal="up">
          <div class="md:col-span-2">
            <div class="text-5xl md:text-6xl font-semibold text-stone-200 tracking-tight leading-none">
              09
            </div>
          </div>
          <div class="md:col-span-10">
            <h3 class="text-xl md:text-2xl font-semibold text-stone-900 tracking-tight">
              Schema Marketing: Teach Google your motel
            </h3>
            <p class="mt-2 text-stone-500 leading-relaxed">
              Schema is the translator between your website and search engines. Done correctly, it turns your motel into structured, readable data—making it easier for Google and AI tools to surface you for high-intent searches.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-white py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="rounded-2xl border border-stone-200 bg-[#F9F9F8] p-10 text-center" data-reveal="up">
        <h2 class="text-2xl md:text-3xl font-semibold text-stone-900 tracking-tight text-balance">
          Book a motel marketing strategy session.
        </h2>
        <p class="mt-4 text-stone-500 leading-relaxed max-w-2xl mx-auto">
          We&apos;ll show you what to fix first so direct bookings become predictable.
        </p>
        <a
          href="/contact?topic=consultancy&message=Please%20book%20me%20in%20for%20a%20free%20motel%20marketing%20strategy%20session."
          class="mt-7 inline-flex items-center justify-center rounded-lg bg-[#4A554E] px-8 py-4 text-base font-medium text-white shadow-sm hover:bg-[#3d4640] hover:shadow-lg transition"
        >
          Book Your Free Strategy Session
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
