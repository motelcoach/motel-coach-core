---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

// Extract unique categories from your markdown files. 
// If a file doesn't have a category yet, we label it 'General'.
const categories = ['All', ...new Set(sortedPosts.map(post => post.data.category || 'General'))].sort();

const NON_CANONICAL_PARAMS = ['offset', 'reversePaginate', 'category', 'author'];
const hasNonCanonicalParams = NON_CANONICAL_PARAMS.some(p => Astro.url.searchParams.has(p));
const fullCanonical = new URL(Astro.url.href, Astro.site ?? Astro.url.origin);
---

<BaseLayout title="Motel Operations Library" noindex={hasNonCanonicalParams} canonicalURL={fullCanonical}>
  <header class="py-16 md:py-20 bg-[#F9F9F8] border-b border-stone-200">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-4xl md:text-5xl font-semibold text-stone-900 tracking-tight">
        The Operations Library
      </h1>
      <p class="mt-4 text-lg text-stone-500 max-w-2xl leading-relaxed">
        Actionable strategies, checklists, and guides for independent motel operators.
      </p>
      <form class="mt-8 flex flex-col sm:flex-row gap-3 max-w-md" action="https://hooks.zapier.com/hooks/catch/26131104/upwyerc/" method="POST" aria-label="Subscribe to blog updates">
        <input type="hidden" name="source_page" value="Blog Index" />
        <input type="hidden" name="form_type" value="newsletter" />
        <label for="blog-email" class="sr-only">Email address</label>
        <input
          id="blog-email"
          type="email"
          name="email"
          placeholder="you@example.com"
          required
          class="flex-1 min-w-0 px-4 py-3 rounded-lg border border-stone-200 bg-white text-stone-900 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-[#4A554E] focus:border-transparent"
        />
        <button
          type="submit"
          class="px-5 py-3 bg-[#4A554E] text-white font-medium rounded-lg hover:bg-[#3d4640] transition-colors whitespace-nowrap"
        >
          Get New Guides Free
        </button>
      </form>
    </div>
  </header>

  <section class="py-12 bg-brand-50 border-b border-stone-200 sticky top-[72px] z-40 shadow-sm">
    <div class="max-w-7xl mx-auto px-6 flex flex-wrap gap-3 justify-center" id="filter-container">
      {categories.map((category, index) => (
        <button 
          class={`filter-btn px-6 py-2.5 rounded-full font-bold text-sm transition-all duration-300 border ${index === 0 ? 'bg-[#4A554E] text-white border-[#4A554E] shadow-md' : 'bg-white text-stone-900 border-stone-200 hover:border-[#4A554E] hover:text-[#4A554E] shadow-sm'}`}
          data-filter={category}
        >
          {category}
        </button>
      ))}
    </div>
  </section>

  <section class="py-20 bg-brand-50 min-h-screen">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" id="blog-grid">
        {sortedPosts.map(post => (
          <article class="blog-card group bg-white p-8 rounded-2xl border border-stone-200 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 flex flex-col h-full" data-category={post.data.category || 'General'}>
            
            <div class="text-xs font-semibold text-[#4A554E] mb-4 uppercase tracking-widest flex justify-between items-center">
              <span class="text-stone-400">{new Date(post.data.pubDate).toLocaleDateString('en-AU', { month: 'long', year: 'numeric' })}</span>
              <span class="bg-[#4A554E]/10 text-[#4A554E] px-3 py-1 rounded-full">{post.data.category || 'General'}</span>
            </div>
            
            <h2 class="text-2xl font-semibold leading-tight mb-4">
              <a href={`/blog/${post.slug}`} class="text-stone-900 group-hover:text-[#4A554E] transition-colors">
                {post.data.title}
              </a>
            </h2>
            
            <p class="text-stone-500 flex-grow mb-8 line-clamp-3 leading-relaxed">
              {post.data.executiveSummary}
            </p>
            
          </article>
        ))}
      
  </section>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.blog-card');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => {
          b.classList.remove('bg-[#4A554E]', 'text-white', 'border-[#4A554E]', 'shadow-md');
          b.classList.add('bg-white', 'text-stone-900', 'border-stone-200');
        });

        btn.classList.remove('bg-white', 'text-stone-900', 'border-stone-200');
        btn.classList.add('bg-[#4A554E]', 'text-white', 'border-[#4A554E]', 'shadow-md');

        const selectedCategory = btn.getAttribute('data-filter');
        
        cards.forEach(card => {
          const htmlCard = card as HTMLElement; 
          if (selectedCategory === 'All' || card.getAttribute('data-category') === selectedCategory) {
            htmlCard.style.display = 'flex';
          } else {
            htmlCard.style.display = 'none';
          }
        });
      });
    });
  });
</script>