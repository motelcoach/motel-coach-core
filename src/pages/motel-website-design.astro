---
import BaseLayout from '../layouts/BaseLayout.astro';
import PartnerGrid from '../components/PartnerGrid.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "@id": "https://motelcoach.com.au/motel-website-design#service",
      "name": "Motel Website Design",
      "description": "High-performance, conversion-engineered motel website design for independent Australian motels. Built for speed, direct bookings, and AI search visibility.",
      "provider": {
        "@type": "Organization",
        "@id": "https://motelcoach.com.au/#organization",
        "name": "Motel Coach",
        "url": "https://motelcoach.com.au",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "29/97 Creek St",
          "addressLocality": "Brisbane City",
          "addressRegion": "QLD",
          "postalCode": "4000",
          "addressCountry": "AU"
        }
      },
      "areaServed": {
        "@type": "Country",
        "name": "Australia"
      },
      "serviceType": "Web Design & Development",
      "offers": {
        "@type": "Offer",
        "price": "29",
        "priceCurrency": "AUD",
        "priceSpecification": {
          "@type": "RecurringCharge",
          "billingIncrement": "P1M",
          "description": "Monthly hosting and security management"
        }
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why is my current motel website losing me 7% in conversions?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "If your site takes 4 seconds to load instead of 2, the cumulative friction causes 14% of potential bookers to abandon the site. For a 20-room motel, that is thousands of dollars in lost direct revenue every month. Speed is the primary barrier to direct booking; our high-performance builds remove that barrier instantly."
          }
        },
        {
          "@type": "Question",
          "name": "Why show Booking.com reviews on my own motel website?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Because guests trust them. By displaying them natively, you satisfy their need for Social Trust without letting them leave your site. This is a core tactic in modern motel marketing to keep the guest in your booking funnel and prevent them from bouncing back to an OTA."
          }
        },
        {
          "@type": "Question",
          "name": "Can a new website actually reduce my OTA dependency?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. We build a Best Rate Guarantee directly into your site as a simple membership or Unlock price. This allows you to legally offer lower direct rates without triggering Rate Parity penalties from the OTAs, giving guests a logical, financial reason to book direct."
          }
        },
        {
          "@type": "Question",
          "name": "How much does a motel website cost to maintain, and how long does the build take?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Hosting and technical security are managed for $29 per month. A standard high-conversion build has an estimated duration of 4 weeks, ensuring you move from a leak to a lead in just one month."
          }
        }
      ]
    }
  ]
};
---

<BaseLayout
  title="Motel Website Design | Stop Donating 15% to Booking.com"
  description="High-performance motel websites engineered for direct bookings. Speed-optimised, review-integrated, and AI-structured so you own the guest relationship and stop leaking revenue to OTAs."
>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <!-- ═══════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════ -->
  <section class="bg-white pt-24 pb-16 md:pt-32 md:pb-24 border-b border-stone-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">

        <span class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-[#4A554E] mb-6">
          <span class="h-px w-6 bg-[#4A554E]"></span>
          Motel Websites
        </span>

        <h1 class="text-5xl md:text-6xl lg:text-7xl font-semibold text-stone-900 leading-[1.05] tracking-tight text-balance mb-6">
          Stop Donating 15%<br />
          <span class="text-stone-400">to Booking.com.</span>
        </h1>

        <p class="text-lg md:text-xl text-stone-500 leading-relaxed max-w-2xl mb-10 text-balance">
          When your site is slow, guests flee to OTAs and the motel next door. A high-performance motel website is the only way to protect your margins and own the guest relationship.
        </p>

        <div class="flex flex-wrap items-center gap-4">
          <a
            href="#audit-form"
            class="px-7 py-3.5 bg-[#4A554E] text-white text-base font-medium rounded-lg hover:bg-[#3d4640] transition-colors shadow-sm"
          >
            Request a Website Audit
          </a>
          <a
            href="/motel-consultancy"
            class="px-7 py-3.5 bg-white border border-stone-200 text-stone-900 text-base font-medium rounded-lg hover:bg-stone-50 transition-colors shadow-sm"
          >
            Learn About Our Consultancy
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PARTNER GRID
  ═══════════════════════════════════════════ -->
  <PartnerGrid />

  <!-- Accom News callout -->
  <div class="bg-stone-50 border-b border-stone-200 py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs text-stone-500 text-center">
        <span class="font-semibold text-stone-700">Latest insights featured in Accom News:</span>
        &ldquo;How to Win your First 21 Days as a Motel Manager&rdquo;
      </p>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       THE PROBLEM + KEY NUMBERS
  ═══════════════════════════════════════════ -->
  <section class="bg-[#F9F9F8] py-20 md:py-28 border-b border-stone-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="max-w-2xl mb-16">
        <h2 class="text-3xl md:text-4xl font-semibold text-stone-900 tracking-tight mb-5">
          Your website is leaking guests to Booking.com right now.
        </h2>
        <p class="text-lg text-stone-500 leading-relaxed">
          Most independent motel websites are "digital brochures" built by generic agencies that don't understand motel management. These sites are slow, mobile-clumsy, and structurally designed to leak guests back to Booking.com. Motel Coach is a specialist motel operations and marketing company — we have run many motels, cleaned thousands of rooms, and checked in thousands of guests. We know what converts a visitor on your website to a paying guest.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">

        <div class="bg-white rounded-2xl border border-stone-200 p-8 shadow-sm">
          <p class="text-5xl font-bold text-[#4A554E] mb-3">7%</p>
          <p class="text-sm font-semibold text-stone-900 mb-2">Direct Booking Loss Per Second</p>
          <p class="text-sm text-stone-500 leading-relaxed">
            A 1-second increase in website load time costs you a 7% loss in direct bookings. Speed is not aesthetic — it is revenue.
          </p>
        </div>

        <div class="bg-white rounded-2xl border border-stone-200 p-8 shadow-sm">
          <p class="text-5xl font-bold text-[#4A554E] mb-3">53%</p>
          <p class="text-sm font-semibold text-stone-900 mb-2">Guests Need Reviews to Book</p>
          <p class="text-sm text-stone-500 leading-relaxed">
            53% of website visitors won't book if they can't see reviews. If your site sends them to Google to find them, you've lost the sale.
          </p>
        </div>

        <div class="bg-white rounded-2xl border border-stone-200 p-8 shadow-sm">
          <p class="text-5xl font-bold text-[#4A554E] mb-3">50%+</p>
          <p class="text-sm font-semibold text-stone-900 mb-2">Bookings Made on Mobile</p>
          <p class="text-sm text-stone-500 leading-relaxed">
            Over 50% of bookings are made on a mobile phone — often on a regional 4G connection. A slow, desktop-first site kills conversion before the guest sees your rooms.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FEATURE BLOCKS (ALTERNATING)
  ═══════════════════════════════════════════ -->

  <!-- Feature 1: Speed -->
  <section class="bg-white py-20 md:py-28 border-b border-stone-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 md:grid-cols-2 md:items-center">

        <div>
          <span class="text-xs font-bold uppercase tracking-widest text-[#4A554E] mb-3 block">Feature 01</span>
          <h2 class="text-3xl md:text-4xl font-semibold text-stone-900 tracking-tight mb-5">
            The 1-Second Speed Tax
          </h2>
          <p class="text-stone-500 leading-relaxed mb-4">
            Website speed is not a "technicality" — it is a conversion killer. Industry data for 2026 is clear: a 1-second increase in website load time costs you a 7% loss in direct booking conversions.
          </p>
          <p class="text-stone-500 leading-relaxed">
            If your site is heavy or outdated, you are effectively paying a 7% tax on your own revenue before a guest even sees your rooms. We build using high-speed, clean-code architecture to ensure your site loads instantly on mobile, where 70% of your visitors are. Our websites are built with class-leading performance standards.
          </p>
        </div>

        <div class="bg-gradient-to-br from-stone-900 to-[#4A554E] rounded-2xl p-8 text-white">
          <p class="text-xs font-semibold uppercase tracking-widest text-stone-300 mb-6">Performance Benchmark</p>
          <div class="space-y-5">
            <div>
              <div class="flex justify-between text-sm mb-2">
                <span class="text-stone-200">Typical motel site</span>
                <span class="font-semibold text-red-300">4.8s load</span>
              </div>
              <div class="h-2 bg-white/10 rounded-full overflow-hidden">
                <div class="h-full bg-red-400/60 rounded-full" style="width: 96%"></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between text-sm mb-2">
                <span class="text-stone-200">Motel Coach build</span>
                <span class="font-semibold text-green-300">&lt; 1.5s load</span>
              </div>
              <div class="h-2 bg-white/10 rounded-full overflow-hidden">
                <div class="h-full bg-green-400/70 rounded-full" style="width: 30%"></div>
              </div>
            </div>
            <p class="text-xs text-stone-400 pt-2">Measured on 4G mobile connection — the road-tripper benchmark.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Feature 2: Trust Leak -->
  <section class="bg-[#F9F9F8] py-20 md:py-28 border-b border-stone-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 md:grid-cols-2 md:items-center">

        <div class="order-2 md:order-1 bg-white rounded-2xl border border-stone-200 p-8 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-widest text-stone-400 mb-6">The Trust Leak Flow</p>
          <div class="space-y-4">
            {[
              { step: "01", label: "Guest lands on your website", status: "safe" },
              { step: "02", label: "Can't find reviews — leaves to check Google", status: "danger" },
              { step: "03", label: "Now on Booking.com: competitors one click away", status: "danger" },
              { step: "04", label: "Books the competitor. You pay 0% commission on nothing.", status: "lost" },
            ].map(({ step, label, status }) => (
              <div class={`flex items-start gap-4 p-3 rounded-lg ${status === 'safe' ? 'bg-green-50 border border-green-100' : status === 'danger' ? 'bg-amber-50 border border-amber-100' : 'bg-red-50 border border-red-100'}`}>
                <span class={`text-xs font-bold tabular-nums mt-0.5 ${status === 'safe' ? 'text-green-600' : status === 'danger' ? 'text-amber-600' : 'text-red-600'}`}>{step}</span>
                <p class="text-sm text-stone-700">{label}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="order-1 md:order-2">
          <span class="text-xs font-bold uppercase tracking-widest text-[#4A554E] mb-3 block">Feature 02</span>
          <h2 class="text-3xl md:text-4xl font-semibold text-stone-900 tracking-tight mb-5">
            Plugging the "Trust Leak" with Integrated Reviews
          </h2>
          <p class="text-stone-500 leading-relaxed mb-6">
            The #1 reason guests leave a motel website is to "check the reviews." The moment they leave your site, you have lost control of the sale — they are now in the OTA ecosystem where your competitors are one click away.
          </p>
          <p class="text-stone-500 leading-relaxed mb-6">
            We eliminate this Trust Leak by incorporating Google and Booking.com reviews directly into your website.
          </p>
          <ul class="space-y-3">
            {[
              { label: "Social Proof", desc: "Guests see verified, recent feedback without leaving your page." },
              { label: "Authority", desc: "Showing Booking.com reviews on your own site signals you have nothing to hide." },
              { label: "Conversion", desc: "Keeps the guest in your booking funnel from discovery to checkout." },
            ].map(({ label, desc }) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 h-5 w-5 flex-shrink-0 flex items-center justify-center rounded-full bg-[#4A554E]/10 text-[#4A554E]">
                  <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <p class="text-sm text-stone-600"><span class="font-semibold text-stone-900">{label}:</span> {desc}</p>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- Feature 3: Specialist Difference -->
  <section class="bg-white py-20 md:py-28 border-b border-stone-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 md:grid-cols-2 md:items-center">

        <div>
          <span class="text-xs font-bold uppercase tracking-widest text-[#4A554E] mb-3 block">Feature 03</span>
          <h2 class="text-3xl md:text-4xl font-semibold text-stone-900 tracking-tight mb-5">
            The Specialist Difference
          </h2>
          <p class="text-stone-500 leading-relaxed mb-6">
            Generic web designers focus on aesthetics. We focus on Revenue Intelligence. A Motel Coach website is engineered around the operational realities of the industry.
          </p>
          <ul class="space-y-4">
            {[
              {
                label: "Seamless PMS Integration",
                desc: "Whether you use GuestPoint, Little Hotelier, or a legacy system, we ensure your Book Now flow is frictionless and your inventory is always live."
              },
              {
                label: 'The "Fact Layer" for AI',
                desc: 'AI Answer Engines scrape your site to recommend you. We embed structured data (Schema) so AI knows you have "king beds," "trailer parking," and "ground-floor access" without a guest needing to hunt for it.'
              },
            ].map(({ label, desc }) => (
              <li class="flex items-start gap-4 p-4 bg-stone-50 rounded-xl border border-stone-100">
                <span class="mt-0.5 h-8 w-8 flex-shrink-0 flex items-center justify-center rounded-full bg-[#4A554E]/10">
                  <svg class="h-4 w-4 text-[#4A554E]" viewBox="0 0 16 16" fill="none"><path d="M3 8l4 4 6-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <div>
                  <p class="text-sm font-semibold text-stone-900 mb-1">{label}</p>
                  <p class="text-sm text-stone-500 leading-relaxed">{desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

        <div class="grid grid-cols-2 gap-4">
          {[
            { metric: "GuestPoint", sub: "PMS Integration" },
            { metric: "Little Hotelier", sub: "PMS Integration" },
            { metric: "Schema", sub: "AI Fact Layer" },
            { metric: "$29/mo", sub: "Hosting & Security" },
          ].map(({ metric, sub }) => (
            <div class="bg-gradient-to-br from-[#4A554E] to-stone-900 text-white rounded-2xl p-6 flex flex-col justify-between min-h-[120px]">
              <p class="text-base font-bold leading-tight">{metric}</p>
              <p class="text-xs text-stone-300 mt-2">{sub}</p>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       BUILD PROCESS
  ═══════════════════════════════════════════ -->
  <section class="bg-[#F9F9F8] py-20 md:py-28 border-b border-stone-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="max-w-2xl mb-14">
        <h2 class="text-3xl md:text-4xl font-semibold text-stone-900 tracking-tight mb-4">
          The Build Process: From Audit to Launch
        </h2>
        <p class="text-lg text-stone-500 leading-relaxed">
          We move fast because we know you are stretched thin. Our motel consultancy approach ensures the project doesn't bog you down in technical jargon.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {[
          {
            step: "01",
            heading: "The Digital Audit",
            body: "We analyse your local market, identify what guests are searching for, and map how your motel can capture the most exposure in organic and AI search results."
          },
          {
            step: "02",
            heading: "Structural Mapping",
            body: "We map your existing website and create new pages and content aligned to what your target market is actively searching — ensuring you rank for demand, not just brand."
          },
          {
            step: "03",
            heading: "PMS & Tech Integration",
            body: "We connect your inventory and configure your direct booking interception tools — rate guarantees, review embedding, and Schema markup — so the site works as hard as you do."
          },
        ].map(({ step, heading, body }) => (
          <div class="bg-white rounded-2xl border border-stone-200 p-8 shadow-sm relative overflow-hidden">
            <span class="absolute top-4 right-5 text-6xl font-bold text-stone-100 leading-none select-none">{step}</span>
            <p class="text-xs font-bold uppercase tracking-widest text-[#4A554E] mb-3">Step {step}</p>
            <h3 class="text-lg font-semibold text-stone-900 mb-3">{heading}</h3>
            <p class="text-sm text-stone-500 leading-relaxed">{body}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       LEAD GENERATION FORM
  ═══════════════════════════════════════════ -->
  <section id="audit-form" class="bg-white py-20 md:py-28 border-b border-stone-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto">

        <div class="text-center mb-10">
          <span class="text-xs font-bold uppercase tracking-widest text-[#4A554E] mb-3 block">Free Service</span>
          <h2 class="text-3xl md:text-4xl font-semibold text-stone-900 tracking-tight mb-4">
            Request a Website Audit
          </h2>
          <p class="text-stone-500 leading-relaxed">
            Tell us about your property. We'll assess your current site's speed, trust signals, and conversion architecture and send you a priority action list.
          </p>
        </div>

        <div id="website-audit-success" class="hidden bg-[#F9F9F8] rounded-2xl border border-stone-200 p-10 text-center">
          <p class="text-2xl font-semibold text-stone-900 mb-2">Audit request received.</p>
          <p class="text-stone-500">We&apos;ll assess your site and send you a priority action list shortly.</p>
        </div>
        <form
          id="website-audit-form"
          action="https://hooks.zapier.com/hooks/catch/26131104/upwyerc/"
          method="POST"
          class="bg-[#F9F9F8] rounded-2xl border border-stone-200 p-8 space-y-4"
          aria-label="Request a motel website audit"
        >
          <input type="hidden" name="source_page" value="Motel Website Design" />
          <input type="hidden" name="form_type" value="website-audit" />

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="audit-name" class="block text-xs font-semibold text-stone-700 mb-1.5">Your Name</label>
              <input
                id="audit-name"
                type="text"
                name="name"
                required
                placeholder="Ben Douglas"
                class="w-full px-4 py-3 rounded-lg border border-stone-200 bg-white text-stone-900 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-[#4A554E] focus:border-transparent text-sm"
              />
            </div>
            <div>
              <label for="audit-motel" class="block text-xs font-semibold text-stone-700 mb-1.5">Motel Name</label>
              <input
                id="audit-motel"
                type="text"
                name="motel_name"
                required
                placeholder="Blue Hills Motor Inn"
                class="w-full px-4 py-3 rounded-lg border border-stone-200 bg-white text-stone-900 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-[#4A554E] focus:border-transparent text-sm"
              />
            </div>
          </div>

          <div>
            <label for="audit-email" class="block text-xs font-semibold text-stone-700 mb-1.5">Email Address</label>
            <input
              id="audit-email"
              type="email"
              name="email"
              required
              placeholder="you@yourmotel.com.au"
              class="w-full px-4 py-3 rounded-lg border border-stone-200 bg-white text-stone-900 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-[#4A554E] focus:border-transparent text-sm"
            />
          </div>

          <div>
            <label for="audit-url" class="block text-xs font-semibold text-stone-700 mb-1.5">Current Website URL</label>
            <input
              id="audit-url"
              type="text"
              name="website"
              placeholder="www.yourmotel.com.au"
              class="w-full px-4 py-3 rounded-lg border border-stone-200 bg-white text-stone-900 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-[#4A554E] focus:border-transparent text-sm"
            />
          </div>

          <button
            type="submit"
            class="w-full px-6 py-3.5 bg-[#4A554E] text-white text-sm font-semibold rounded-lg hover:bg-[#3d4640] transition-colors"
          >
            Request My Free Website Audit
          </button>

          <p class="text-xs text-stone-400 text-center leading-relaxed">
            By submitting this form, you'll receive your audit results along with a short series of follow-up emails on motel management and direct booking strategies. Unsubscribe any time.
          </p>
        </form>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FAQ
  ═══════════════════════════════════════════ -->
  <section class="bg-[#F9F9F8] py-20 md:py-28 border-b border-stone-200">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <h2 class="text-3xl md:text-4xl font-semibold text-stone-900 tracking-tight mb-10">
        Motel Website FAQ
      </h2>

      <div class="space-y-3">
        {[
          {
            q: "Why is my current site losing me 7% in conversions?",
            a: "If your site takes 4 seconds to load instead of 2, the cumulative friction causes 14% of potential bookers to abandon the site. For a 20-room motel, that is thousands of dollars in lost direct revenue every month. Speed is the primary barrier to direct booking; our high-performance builds remove that barrier instantly."
          },
          {
            q: "Why show Booking.com reviews on my own site?",
            a: "Because guests trust them. By displaying them natively, you satisfy their need for Social Trust without letting them leave your site. This is a core tactic in modern motel marketing to keep the guest in your booking funnel and prevent them from bouncing back to an OTA."
          },
          {
            q: "Can a new website actually reduce my OTA dependency?",
            a: 'Yes. We build a "Best Rate Guarantee" directly into your site as a simple membership or "Unlock" price. This allows you to legally offer lower direct rates without triggering Rate Parity penalties from the OTAs. It provides a logical, financial reason for guests to book direct.'
          },
          {
            q: "How much does it cost to maintain, and how long does it take?",
            a: "We pride ourselves on transparent, operational costs. Hosting and technical security are managed for $29 per month. A standard high-conversion build has an estimated duration of 4 weeks, ensuring you move from a leak to a lead in just one month."
          },
        ].map(({ q, a }) => (
          <details class="group rounded-xl border border-stone-200 bg-white p-4">
            <summary class="flex cursor-pointer items-center justify-between gap-4 text-left list-none">
              <span class="text-sm md:text-base font-semibold text-stone-900">{q}</span>
              <span class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full border border-stone-300 text-stone-500 transition-transform group-open:rotate-45 text-lg leading-none">
                +
              </span>
            </summary>
            <p class="mt-3 text-sm text-stone-500 leading-relaxed">{a}</p>
          </details>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       BOTTOM CTA
  ═══════════════════════════════════════════ -->
 
<script>
  const form = document.getElementById('website-audit-form');
  if (form) {
    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      const formEl = e.target;
      const btn = formEl.querySelector('button[type="submit"]');
      const originalText = btn.textContent.trim();

      const urlInput = formEl.querySelector('#audit-url');
      if (urlInput) {
        let v = urlInput.value.trim();
        if (v && !/^https?:\/\//i.test(v)) {
          urlInput.value = 'https://' + v;
        }
      }

      btn.disabled = true;
      btn.textContent = 'Sending...';

      try {
        const formData = new FormData(formEl);
        const data = new URLSearchParams(formData);

        await fetch(formEl.action, {
          method: 'POST',
          mode: 'no-cors',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded'
          },
          body: data.toString()
        });

        btn.textContent = 'Sent Successfully!';
        formEl.reset();
        formEl.classList.add('hidden');
        document.getElementById('website-audit-success').classList.remove('hidden');
      } catch (err) {
        console.error(err);
        btn.disabled = false;
        btn.textContent = originalText;
        alert('Something went wrong. Please check your connection and try again.');
      }
    });
  }
</script>
</BaseLayout>
