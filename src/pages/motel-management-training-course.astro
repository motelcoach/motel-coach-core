---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';
import LucideIcon from '../components/LucideIcon.astro';

const entry = await getEntry('pages', 'motel-management-training-course');
---

<head>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Course",
      "name": "Motel Management Training Course",
      "description": "Beginner-friendly and advanced motel management course covering operations, motel systems, front desk training, and revenue management for independent Australian motels.",
      "provider": {
        "@type": "Organization",
        "name": "Motel Coach",
        "url": "https://motelcoach.com.au"
      },
      "educationalLevel": [
        "Beginner",
        "Intermediate",
        "Professional"
      ],
      "inLanguage": "en-AU",
      "courseCode": "MC-MOTEL-MGMT-COURSE",
      "url": "https://motelcoach.com.au/motel-management-training-course",
      "hasCourseInstance": [
        {
          "@type": "CourseInstance",
          "name": "Self-Guided Motel Management",
          "courseMode": "online",
          "description": "Self-guided access to the full motel management syllabus without formal assessment.",
          "offers": {
            "@type": "Offer",
            "price": "89",
            "priceCurrency": "AUD",
            "availability": "https://schema.org/InStock"
          }
        },
        {
          "@type": "CourseInstance",
          "name": "Self-Guided + Testing",
          "courseMode": "online",
          "description": "Self-guided learning with assessments and certificate of completion.",
          "offers": {
            "@type": "Offer",
            "price": "189",
            "priceCurrency": "AUD",
            "availability": "https://schema.org/InStock"
          }
        },
        {
          "@type": "CourseInstance",
          "name": "Priority Course with 1:1 Coaching",
          "courseMode": "online",
          "description": "Intensive motel management course with 1:1 coaching and implementation support.",
          "offers": {
            "@type": "Offer",
            "price": "675",
            "priceCurrency": "AUD",
            "availability": "https://schema.org/InStock"
          }
        }
      ],
      "about": [
        "motel management",
        "motel system",
        "how to run a motel business",
        "front desk training",
        "motel marketing",
        "motel seo"
      ]
    }
  </script>

<script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "I have no experience, is motel management right for me?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. The motel management course is designed to be beginner friendly and prepares you for day one in a real motel, including front desk training and motel system basics."
          }
        },
        {
          "@type": "Question",
          "name": "I'm an experienced manager – what can you offer me?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Experienced managers use this motel management course to tighten their motel system, improve revenue management, and upgrade motel marketing across OTAs and direct channels."
          }
        },
        {
          "@type": "Question",
          "name": "I'm not good on the computer will I cope?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The systems used in motels are very basic. We can get you up to speed in a calm environment using a real motel system before you start your first role."
          }
        },
        {
          "@type": "Question",
          "name": "Do I get a certificate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Our base Self-Guided course does not include a certificate. The Self-Guided + Testing and Priority Course options provide a certificate of completion once you meet the required competency, and we support any students who need extra help to get there."
          }
        },
        {
          "@type": "Question",
          "name": "What if I don't enjoy the course?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We totally appreciate that not all courses will suit each student. Our courses come with a 10-day money back guarantee. If you do decide the course is not right for you - we are still here and happy to answer any of your motel related questions and you will still be part of our community."
          }
        },
          {
          "@type": "Question",
          "name": "Can you help me with my motel?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, we provide tailored services for motels to increase their performance. Our key focus areas are optimization of existing channels, staffing, marketing and revenue management."
          }
        }
      ]
    }
  </script>

</head>

<BaseLayout title={entry.data.title}>
  <!-- 1. Executive Hero (aligned with Marketing/Management pillars) -->
  <section class="bg-[#F9F9F8] border-b border-stone-200 py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-12 gap-12 items-start">
        <div class="md:col-span-8">
          <p class="text-xs font-semibold uppercase tracking-widest text-[#4A554E] mb-4">
            Motel Management Course
          </p>
          <h1 class="text-4xl md:text-5xl font-semibold text-stone-900 tracking-tight text-balance mb-6">
            Avoid costly mistakes in your first motel role.
          </h1>
          <p class="text-lg text-stone-500 leading-relaxed text-balance">
            Become a confident motel manager with practical motel management short courses. No prior experience required.
          </p>
          <p class="mt-4 text-lg text-stone-500 leading-relaxed">
            Proven in the field, supported by the industry, and built around a clear motel system instead of trial-and-error.
          </p>
          <div class="mt-6 flex flex-col sm:flex-row gap-3">
            <a
              href="#curriculum"
              class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-[#4A554E] text-white font-medium rounded-lg hover:bg-[#3d4640] transition-colors shadow-sm"
            >
              View course modules
            </a>
          </div>
        </div>

        <div class="md:col-span-4">
          <div class="bg-white border border-stone-200 p-6 rounded-xl shadow-sm sticky top-32">
            <p class="text-xs font-semibold uppercase tracking-widest text-stone-400 mb-4">
              Course badge
            </p>
            <ul class="space-y-4 text-sm text-stone-700">
              <li class="flex items-start gap-3">
                <span class="mt-1 h-6 w-6 flex items-center justify-center rounded-full bg-[#4A554E]/10 text-[#4A554E]">
                  <LucideIcon name="check-circle-2" size={18} class="text-[#4A554E]" />
                </span>
                <span><strong class="text-stone-900">Certificate included</strong><br />Receive a certificate of completion when you meet course competency.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 h-6 w-6 flex items-center justify-center rounded-full bg-[#4A554E]/10 text-[#4A554E]">
                  <LucideIcon name="check-circle-2" size={18} class="text-[#4A554E]" />
                </span>
                <span><strong class="text-stone-900">10-day guarantee</strong><br />Courses include a 10-day money back guarantee if it isn&apos;t the right fit.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 h-6 w-6 flex items-center justify-center rounded-full bg-[#4A554E]/10 text-[#4A554E]">
                  <LucideIcon name="check-circle-2" size={18} class="text-[#4A554E]" />
                </span>
                <span><strong class="text-stone-900">Beginner friendly</strong><br />Designed for new managers and those with limited computer or motel experience.</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Accom News Authority Bar -->
  <section class="bg-stone-50 border-y border-stone-200 py-6">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-stone-400 mb-1">
        As featured in Accom News
      </p>
      <p class="text-base text-stone-700 italic font-serif">
        &quot;How to Win your First 21 Days as a Motel Manager&quot;
      </p>
    </div>
  </section>

  <!-- 3. Experience Fit + Pricing -->
  <section id="curriculum" class="bg-white py-24">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-2xl md:text-3xl font-semibold text-stone-900 tracking-tight text-balance mb-10">
        Motel Training Suitable for All Experience Levels
      </h2>
      <div class="space-y-8">
        <div class="space-y-3">
          {[
            'Inexperienced & aspiring motel managers.',
            'Experienced managers looking to increase their capabilities.',
            'Motel owners wanting to develop their on-site management team.',
          ].map((t) => (
            <div class="flex items-start gap-3 text-sm text-stone-600">
              <span class="mt-0.5 h-5 w-5 flex items-center justify-center rounded-full bg-[#4A554E]/10 text-[#4A554E]">
                <LucideIcon name="check" size={18} class="text-[#4A554E]" />
              </span>
              <span>{t}</span>
            </div>
          ))}
        </div>

        <div class="grid md:grid-cols-3 gap-6 mt-8">
          <div class="bg-white border-2 border-stone-200 rounded-2xl p-8 shadow-sm flex flex-col">
            <h3 class="text-lg font-semibold text-stone-900 tracking-tight mb-2">
              Self-Guided
            </h3>
            <p class="text-3xl font-semibold text-stone-900 mb-1">$89</p>
            <p class="text-xs uppercase tracking-widest text-stone-400 mb-3">
              <span class="inline-flex items-center gap-2">
                <span>Course duration: 7–21 days</span>
                <LucideIcon name="dot" size={18} class="text-stone-400" />
                <span>No certificate</span>
              </span>
            </p>
            <p class="text-sm text-stone-500 leading-relaxed flex-grow">
              Self-guided access to the full course content. Ideal if you want a structured introduction to motel management without formal assessment.
            </p>
            <p class="mt-3 text-sm text-stone-600 flex items-start gap-2">
              <span class="mt-0.5 h-4 w-4 flex items-center justify-center rounded bg-[#4A554E]/10 text-[#4A554E]">
                <LucideIcon name="folder" size={18} class="text-[#4A554E]" />
              </span>
              <span>Includes a Motel Management folder with real-world templates, checklists and documents used to run an independent motel.</span>
            </p>
          </div>

          <div class="relative bg-white border-2 border-[#4A554E] rounded-2xl p-8 shadow-md flex flex-col">
            <span class="absolute -top-3 left-4 inline-flex items-center rounded-full bg-[#4A554E] px-3 py-1 text-[10px] font-semibold uppercase tracking-widest text-white">
              Most Popular
            </span>
            <h3 class="text-lg font-semibold text-stone-900 tracking-tight mb-2">
              Self-Guided + Testing
            </h3>
            <p class="text-3xl font-semibold text-stone-900 mb-1">$189</p>
            <p class="text-sm font-medium text-[#4A554E] mb-3">
              <span class="inline-flex items-center gap-2">
                <span>Course duration: 7–21 days</span>
                <LucideIcon name="dot" size={18} class="text-stone-400" />
                <span>Certificate included</span>
              </span>
            </p>
            <p class="text-sm text-stone-500 leading-relaxed flex-grow">
              Self-guided learning plus structured assessments to validate your competency and award a certificate you can present to owners and employers.
            </p>
            <p class="mt-3 text-sm text-stone-600 flex items-start gap-2">
              <span class="mt-0.5 h-4 w-4 flex items-center justify-center rounded bg-[#4A554E]/10 text-[#4A554E]">
                <LucideIcon name="folder" size={18} class="text-[#4A554E]" />
              </span>
              <span>Includes a Motel Management folder with the templates, checklists and operational documents used in real motels.</span>
            </p>
          </div>

          <div class="bg-white border-2 border-stone-200 rounded-2xl p-8 shadow-sm flex flex-col">
            <h3 class="text-lg font-semibold text-stone-900 tracking-tight mb-2">
              Priority Course
            </h3>
            <p class="text-3xl font-semibold text-stone-900 mb-1">$675</p>
            <p class="text-sm font-medium text-[#4A554E] mb-3">
              <span class="inline-flex items-center gap-2">
                <span>Course duration: 7–21 days</span>
                <LucideIcon name="dot" size={18} class="text-stone-400" />
                <span>Certificate + 1:1 coaching</span>
              </span>
            </p>
            <p class="text-sm text-stone-500 leading-relaxed flex-grow">
              Starting a role and need to learn fast? Our Priority Course pairs you with an experienced motel manager for two full days of intensive coaching, with guided implementation support over 7–21 days.
            </p>
            <p class="mt-3 text-sm text-stone-600 flex items-start gap-2">
              <span class="mt-0.5 h-4 w-4 flex items-center justify-center rounded bg-[#4A554E]/10 text-[#4A554E]">
                <LucideIcon name="folder" size={18} class="text-[#4A554E]" />
              </span>
              <span>Includes the full Motel Management folder of templates and real documents we use to operate motels day-to-day.</span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Instructor Proof -->
  <section class="bg-[#F9F9F8] py-24 border-y border-stone-200">
    <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-12 gap-12 items-start">
      <div class="md:col-span-4 flex justify-center md:justify-start">
        <img
          src="/motel-instructor-benjamin-douglas.jpg"
          alt="Motel Instructor Benjamin Douglas"
          class="w-40 h-40 md:w-48 md:h-48 rounded-2xl object-cover shadow-sm"
          loading="lazy"
        />
      </div>
      <div class="md:col-span-8">
        <h2 class="text-2xl md:text-3xl font-semibold text-stone-900 tracking-tight mb-4">
          Meet your Instructor
        </h2>
        <p class="text-stone-500 leading-relaxed mb-4">
          <strong class="text-stone-900">Benjamin Douglas</strong> is the Lead Instructor at Motel Coach and author of <em>The Essential Guide to Motel Management</em>.
        </p>
        <p class="text-stone-500 leading-relaxed mb-4">
          His background spans operational and commercial leadership across independent motel and hotel groups, progressing from frontline roles through to executive management overseeing
          <strong class="text-stone-900"> 16+ motels</strong>, 10 restaurants, and more than 200 staff.
        </p>
        <p class="text-stone-500 leading-relaxed">
          With experience across regional Australia, Brisbane, and England, Benjamin specialises in profit optimisation, OTA strategy, and practical implementation for independent operators.
        </p>
      </div>
    </div>
  </section>

  <!-- 5. No-Brainer FAQ (Accordion) -->
  <section class="bg-white py-24">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-2xl md:text-3xl font-semibold text-stone-900 tracking-tight text-center mb-10">
        Frequently Asked Questions
      </h2>
      <div class="space-y-4" id="faq-accordion">
        <details class="border-2 border-stone-200 rounded-xl p-4 group">
          <summary class="flex items-center justify-between cursor-pointer list-none">
            <span class="text-sm md:text-base font-semibold text-stone-900">
              I have no experience, is motel management right for me?
            </span>
            <span class="ml-4 text-stone-400 text-2xl md:text-3xl leading-none">
              +
            </span>
          </summary>
          <div class="mt-3 text-sm text-stone-500 leading-relaxed">
            Yes - our training courses are designed to be beginner friendly and to get you ready for day one as a
            <a href="/motel-management" class="text-[#4A554E] font-medium hover:underline">motel manager</a>.
          </div>
        </details>

        <details class="border-2 border-stone-200 rounded-xl p-4 group">
          <summary class="flex items-center justify-between cursor-pointer list-none">
            <span class="text-sm md:text-base font-semibold text-stone-900">
              I&apos;m an experienced manager - what can you offer me?
            </span>
            <span class="ml-4 text-stone-400 text-2xl md:text-3xl leading-none">
              +
            </span>
          </summary>
          <div class="mt-3 text-sm text-stone-500 leading-relaxed">
            For our experienced motel managers we focus on optimizing your operation with a combination of operational, marketing and revenue management strategies.
          </div>
        </details>

        <details class="border-2 border-stone-200 rounded-xl p-4 group">
          <summary class="flex items-center justify-between cursor-pointer list-none">
            <span class="text-sm md:text-base font-semibold text-stone-900">
              I&apos;m not good on the computer will I cope?
            </span>
            <span class="ml-4 text-stone-400 text-2xl md:text-3xl leading-none">
              +
            </span>
          </summary>
          <div class="mt-3 text-sm text-stone-500 leading-relaxed">
            The systems used in motels are very basic. We can get you up to speed in a calm environment using a real motel system before you start your first role.
          </div>
        </details>

        <details class="border-2 border-stone-200 rounded-xl p-4 group">
          <summary class="flex items-center justify-between cursor-pointer list-none">
            <span class="text-sm md:text-base font-semibold text-stone-900">
              Do I get a certificate?
            </span>
            <span class="ml-4 text-stone-400 text-2xl md:text-3xl leading-none">
              +
            </span>
          </summary>
          <div class="mt-3 text-sm text-stone-500 leading-relaxed">
            Our base Self-Guided course does not include a certificate. The Self-Guided + Testing and Priority Course options provide a certificate of completion once you meet the required competency, and we support any students who need extra help to get there.
          </div>
        </details>

        <details class="border-2 border-stone-200 rounded-xl p-4 group">
          <summary class="flex items-center justify-between cursor-pointer list-none">
            <span class="text-sm md:text-base font-semibold text-stone-900">
              What if I don&apos;t enjoy the course?
            </span>
            <span class="ml-4 text-stone-400 text-2xl md:text-3xl leading-none">
              +
            </span>
          </summary>
          <div class="mt-3 text-sm text-stone-500 leading-relaxed">
            We totally appreciate that not all courses will suit each student. Our courses come with a 10-day money back guarantee.
            If you do decide the course is not right for you - we are still here and happy to answer any of your motel related questions and you will still be part of our community.
          </div>
        </details>

        <details class="border-2 border-stone-200 rounded-xl p-4 group">
          <summary class="flex items-center justify-between cursor-pointer list-none">
            <span class="text-sm md:text-base font-semibold text-stone-900">
              Can you help me with my motel?
            </span>
            <span class="ml-4 text-stone-400 text-2xl md:text-3xl leading-none">
              +
            </span>
          </summary>
          <div class="mt-3 text-sm text-stone-500 leading-relaxed">
            Yes, we provide tailored services for motels to increase their performance. Our key focus areas are optimization of existing channels, staffing, marketing and revenue management.
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- 6. Bottom Lead Magnet -->
  <section class="bg-[#F9F9F8] py-24 border-t border-stone-200">
    <div class="max-w-xl mx-auto px-6">
      <h3 class="text-2xl md:text-3xl font-semibold text-stone-900 tracking-tight mb-3 text-balance">
        Download our Free Motel Guide
      </h3>
      <p class="text-stone-500 leading-relaxed mb-6">
        By submitting this form, you’ll receive the Motel Management Guide you requested, along with a short series of follow-up emails to help you understand motel management and your next steps. You can unsubscribe at any time.
      </p>
      <form class="space-y-3" action="https://hooks.zapier.com/hooks/catch/26131104/upwyerc/" method="POST">
        <input type="hidden" name="source_page" value="Motel Management Training Course" />
        <input type="hidden" name="form_type" value="guide-download" />
        <input
          type="email"
          name="email"
          required
          placeholder="you@example.com"
          class="w-full px-4 py-2.5 rounded-lg border border-stone-200 bg-white text-sm text-stone-900 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-[#4A554E] focus:border-transparent"
        />
        <button
          type="submit"
          class="w-full inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-[#4A554E] text-white text-sm font-medium rounded-lg hover:bg-[#3d4640] transition-colors shadow-sm"
        >
          Get the Free Guide
        </button>
      </form>
    </div>
  </section>
</BaseLayout>

